{
    "version":  "0.2.0",
    "configurations":  [
                           {
                               "type":  "node",
                               "request":  "attach",
                               "name":  "Attach to flight-service",
                               "port":  9229,
                               "localRoot":  "${workspaceFolder}/Cotrav_Services/services/flight-service",
                               "remoteRoot":  "${workspaceFolder}/Cotrav_Services/services/flight-service",
                               "sourceMaps":  true,
                               "sourceMapPathOverrides":  {
                                                              "../../*":  "${workspaceFolder}/Cotrav_Services/*"
                                                          },
                               "skipFiles":  [
                                                 "\u003cnode_internals\u003e/**",
                                                 "**/node_modules/**"
                                             ],
                               "restart":  true
                           },
                           {
                               "type":  "node",
                               "request":  "launch",
                               "name":  "Launch flight-service",
                               "runtimeExecutable":  "node",
                               "runtimeArgs":  [
                                                   "--inspect=0.0.0.0:9229",
                                                   "-r",
                                                   "tsx/cjs"
                                               ],
                               "args":  [
                                            "src/app.ts"
                                        ],
                               "cwd":  "${workspaceFolder}/Cotrav_Services/services/flight-service",
                               "sourceMaps":  true,
                               "sourceMapPathOverrides":  {
                                                              "../../*":  "${workspaceFolder}/Cotrav_Services/*"
                                                          },
                               "skipFiles":  [
                                                 "\u003cnode_internals\u003e/**",
                                                 "**/node_modules/**"
                                             ],
                               "env":  {
                                           "NODE_ENV":  "development"
                                       },
                               "outFiles":  [
                                                "${workspaceFolder}/Cotrav_Services/services/flight-service/dist/**/*.js"
                                            ]
                           },
                           {
                               "type":  "node",
                               "request":  "attach",
                               "name":  "Attach to auth-service",
                               "port":  9230,
                               "localRoot":  "${workspaceFolder}/Cotrav_Services/services/auth-service",
                               "remoteRoot":  "${workspaceFolder}/Cotrav_Services/services/auth-service",
                               "sourceMaps":  true,
                               "sourceMapPathOverrides":  {
                                                              "../../*":  "${workspaceFolder}/Cotrav_Services/*"
                                                          },
                               "skipFiles":  [
                                                 "\u003cnode_internals\u003e/**",
                                                 "**/node_modules/**"
                                             ],
                               "restart":  true
                           },
                           {
                               "type":  "node",
                               "request":  "launch",
                               "name":  "Launch auth-service",
                               "console":  "integratedTerminal",
                               "runtimeExecutable":  "node",
                               "runtimeArgs":  [
                                                   "--inspect-brk=0.0.0.0:9230",
                                                   "-r",
                                                   "ts-node/register"
                                               ],
                               "program":  "${workspaceFolder}/Cotrav_Services/services/auth-service/src/index.ts",
                               "cwd":  "${workspaceFolder}/Cotrav_Services/services/auth-service",
                               "sourceMaps":  true,
                               "sourceMapPathOverrides":  {
                                                              "../../*":  "${workspaceFolder}/Cotrav_Services/*"
                                                          },
                               "skipFiles":  [
                                                 "\u003cnode_internals\u003e/**",
                                                 "**/node_modules/**"
                                             ],
                               "env":  {
                                           "NODE_ENV":  "development"
                                       },
                               "envFile":  "${workspaceFolder}/Cotrav_Services/services/auth-service/.env",
                               "outFiles":  [
                                                "${workspaceFolder}/Cotrav_Services/services/auth-service/dist/**/*.js"
                                            ]
                           },
                           {
                               "type":  "node",
                               "request":  "launch",
                               "name":  "Launch auth-service (insecure TLS dev)",
                               "console":  "integratedTerminal",
                               "runtimeExecutable":  "node",
                               "runtimeArgs":  [
                                                   "--inspect-brk=0.0.0.0:9230",
                                                   "-r",
                                                   "ts-node/register"
                                               ],
                               "program":  "${workspaceFolder}/Cotrav_Services/services/auth-service/src/index.ts",
                               "cwd":  "${workspaceFolder}/Cotrav_Services/services/auth-service",
                               "sourceMaps":  true,
                               "sourceMapPathOverrides":  {
                                                              "../../*":  "${workspaceFolder}/Cotrav_Services/*"
                                                          },
                               "skipFiles":  [
                                                 "\u003cnode_internals\u003e/**",
                                                 "**/node_modules/**"
                                             ],
                               "env":  {
                                           "NODE_ENV":  "development",
                                           "NODE_TLS_REJECT_UNAUTHORIZED":  "0"
                                       },
                               "envFile":  "${workspaceFolder}/Cotrav_Services/services/auth-service/.env",
                               "outFiles":  [
                                                "${workspaceFolder}/Cotrav_Services/services/auth-service/dist/**/*.js"
                                            ]
                           }
                       ]
}                                                                          
