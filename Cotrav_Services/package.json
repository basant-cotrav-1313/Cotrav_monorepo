{
  "name": "cotrav-services",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build:packages": "npm run build --workspaces --if-present",
    "build:services": "npm run build --workspaces --if-present",
    "build": "npm run build:packages && npm run build:services",
    "clean": "rimraf --glob \"packages/**/dist\" \"services/**/dist\"",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
