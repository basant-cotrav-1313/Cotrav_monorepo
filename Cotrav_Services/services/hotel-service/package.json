{
  "name": "hotel-service",
  "version": "1.0.0",
  "description": "Hotel microservice",
  "main": "dist/app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "debug": "nodemon --exec \"node --inspect=0.0.0.0:9229 -r ts-node/register\" src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@cotrav/errors": "workspace:*",
    "@cotrav/logger": "workspace:*",
    "@cotrav/middlewares": "workspace:*",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mysql2": "^3.19.0",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.9",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3"
  }
}
