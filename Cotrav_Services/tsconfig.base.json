{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@cotrav/errors": ["packages/errors/dist"],
      "@cotrav/logger": ["packages/logger/dist"],
      "@cotrav/middleware": ["packages/middleware/dist"]
    }
  }
}
