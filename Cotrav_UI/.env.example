# Server host
HOST=your_host_here
WDS_SOCKET_HOST=your_host_here

# API base URLs
VITE_API_BASE_URL=https://example.com/api/hotels    # e.g., demo or placeholder
VITE_CORE_BASE_URL=https://example.com/api         # e.g., demo or placeholder
VITE_AUTH_BASE_URL=http://localhost:4001           # auth-service base URL
VITE_AUTH_REALM=cotrav-OPS                         # default Keycloak realm for login payload
VITE_AUTH_CLIENT_ID=cotrav-OPS-app                # default Keycloak client id for login payload

